# Vakkio Connekkt (Docker) — copia este fichero a ".env" y rellénalo.

# Código de emparejamiento (de la web: Integraciones → Vincular agente).
# Solo es necesario en el PRIMER arranque; caduca en ~15 min, un solo uso.
PAIRING_CODE=XXXX-XXXX

# Credenciales de Tuya Cloud (iot.tuya.com). Se quedan en el contenedor/host.
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=eu

# Opcional (por defecto ya apunta a producción):
# VAKKIO_API=https://sparkk.woobik.dev/api
