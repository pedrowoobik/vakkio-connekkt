# Vakkio Connekkt (Docker) — copia este fichero a ".env" y rellena SOLO lo que uses.
# Arranca cada integración con su profile:
#   docker compose --profile tuya --profile tapo up -d
# Los códigos solo hacen falta el PRIMER arranque (caducan en ~15 min, un solo uso).

# ── Tuya / SmartLife (nube) ────────────────────────────────────────────────
# Código: web → Dispositivos → Integraciones → Vincular agente (Tuya).
PAIRING_CODE_TUYA=XXXX-XXXX
# Credenciales de Tuya Cloud (iot.tuya.com). Se quedan en el contenedor/host.
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=eu

# ── TP-Link Tapo (LOCAL) ───────────────────────────────────────────────────
# Código: web → Dispositivos → TP-Link Tapo → Conectar.
PAIRING_CODE_TAPO=XXXX-XXXX
# Cuenta TP-Link/Tapo (la misma de la app Tapo). Se queda en el contenedor/host.
TAPO_USER=
TAPO_PWD=
# (Opcional) si el host tiene varias interfaces (cable+WiFi), apunta el descubrimiento
# al broadcast de la subred de los enchufes (su IP con .255):
# TAPO_BROADCAST=192.168.1.255

# ── Común (opcional) ───────────────────────────────────────────────────────
# VAKKIO_API=https://vakkio.woobik.dev/api   # por defecto ya apunta a producción
